# ----- Supabase (client-safe) -----
# When these are set the app leaves demo mode and reads live data.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public app URL (used for OAuth redirects)
APP_URL=http://localhost:3000

# ----- Supabase Edge Function secrets (server-only; set via `supabase secrets set`) -----
SUPABASE_SERVICE_ROLE_KEY=
# 32-byte AES key, base64-encoded:  openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=

# ----- Charles Schwab API (PRD §5) -----
SCHWAB_CLIENT_ID=
SCHWAB_CLIENT_SECRET=
SCHWAB_REDIRECT_URI=https://<PROJECT_REF>.supabase.co/functions/v1/schwab-oauth

# ----- Notifications (PRD §11) -----
RESEND_API_KEY=
RESEND_FROM=PremiumPilot <alerts@premiumpilot.app>

# ----- Auth providers (configured in Supabase, not the app) -----
GOOGLE_CLIENT_ID=
GOOGLE_SECRET=
APPLE_CLIENT_ID=
APPLE_SECRET=
